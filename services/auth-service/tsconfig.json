{
  "compilerOptions":{
    "target": "ES2020",
    "module": "NodeNext",
    "lib":["ES2020"],
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noImplicitAny":true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "NodeNext",
    "baseUrl": "./",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*":["./src/*"],
      "@shared*":["../../shared/*"]
    }
  },
  "include": [
    "src/**/*", "../../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}
